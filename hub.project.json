{
  "name": "Hub",
  "globIgnorePaths": ["**/.package-lock.json"],
  "tree": {
    "$className": "DataModel",

    "ServerScriptService": {
      "Game": {
        "$className": "Folder",
        "Modules": {
          "$className": "Folder",
          "Global": { "$path": "src/global/Modules" },
          "Hub": { "$path": "src/places/Hub/Modules" }
        },
        "Packages": {
          "$path": "node_modules"
        }
      },
      "Scripts": {
        "$path": "src/global/scripts/Server"
      }
    },

    "StarterPlayer": {
      "StarterPlayerScripts": {
        "Scripts": {
          "$path": "src/global/scripts/Client"
        }
      }
    },

    "StarterGui": {
      "$className": "StarterGui",
      "$path": "src/global/StarterGui"
    },

    "Workspace": {
      "$className": "Workspace",
      "$path": "src/global/Workspace"
    },

    "ReplicatedStorage": {
      "$className": "ReplicatedStorage",
      "$path": "src/global/ReplicatedStorage"
    }
  }
}
